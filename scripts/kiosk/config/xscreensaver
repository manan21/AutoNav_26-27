# xscreensaver settings for the autonav-kiosk user.
# Drop in to: /home/autonav-kiosk/.xscreensaver
#
# - mode one + phosphor: green CRT-phosphor "SCREEN LOCKED", typed
#   once, then phosphor's text source blocks on sleep so it never
#   retypes or scrolls. Static-feeling, low-effort, no custom hack
#   needed.
# - timeout 24:00:00 is "effectively never": xscreensaver treats
#   timeout=0 as "activate immediately on idle" (NOT disabled) so
#   the workaround is just a very large value.
# - passwdTimeout 00:05:00: 5 minutes for the operator to type the
#   password before the unlock dialog reverts to the screensaver.
# - splash False: no "About xscreensaver" splash on startup.

timeout:                24:00:00
cycle:                  0:00:00
lock:                   True
lockTimeout:            0:00:00
passwdTimeout:          0:05:00

dpmsEnabled:            False
dpmsQuickOff:           False

grabDesktopImages:      False
grabVideoFrames:        False
chooseRandomImages:     False
imageDirectory:

mode:                   one
selected:               0
programs:                                                           \
                phosphor -root -program "echo 'SCREEN LOCKED'; sleep 99999"   \n

textMode:               literal
textLiteral:            SCREEN LOCKED
textFile:
textProgram:
textURL:

fadeSeconds:            0:00:00
fadeTicks:              0
splash:                 False
splashDuration:         0:00:00

visualID:               default
installColormap:        True
verbose:                False
timestamp:              True
fade:                   False
unfade:                 False
captureStderr:          True
ignoreUninstalledPrograms: True

font:                   *-medium-r-*-*-*-180-*-*-*-*-*-*-*
