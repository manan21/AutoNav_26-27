<!--
  AutoNav behavior tree — persistent goal pursuit with GoalBender.

  Flow:
    1. GoalBender checks if the goal is behind the robot
       - If behind: sets an intermediate waypoint ahead and to the side,
         arcing the robot toward the real goal
       - If in front: passes the goal through unchanged
    2. Compute path to the (possibly bent) goal (replan at 1 Hz)
    3. Follow the path
    4. If stuck, cycle through recoveries forever

  Recovery sequence:
    1. BackUp           — reverse out of tight spots
    2. GradientEscape   — follow costmap gradient away from high cost
    3. Clear costmaps   — remove ghost obstacles
    4. Wait 5 s         — let transient obstacles pass
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="999" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <!-- Replan at 1 Hz to keep CPU available for the rest of the
             stack. Fast invalidation detection comes from the
             ReactiveSequence/IsPathValid wrapper around FollowPath
             below, not from raw replan rate — that catches a dead
             path within ~100 ms (BT tick rate) and forces a recovery
             cycle, which the next 1 Hz plan refresh will complete. -->
        <RateController hz="1.0">
          <Sequence name="BendAndPlan">
            <!-- Bend goal if it's behind the robot -->
            <GoalBender input_goal="{goal}" output_goal="{nav_goal}"
              bend_distance="0.8" angle_threshold="1.57" bend_angle="1.05"/>
            <RecoveryNode number_of_retries="1" name="ComputePathRecovery">
              <ComputePathToPose goal="{nav_goal}" path="{path}" planner_id="GridBased"/>
              <Sequence name="PlanRecovery">
                <ClearEntireCostmap name="ClearGlobalCostmap-Context"
                  service_name="global_costmap/clear_entirely_global_costmap"/>
                <Wait wait_duration="1"/>
              </Sequence>
            </RecoveryNode>
          </Sequence>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPathRecovery">
          <!-- ReactiveSequence ticks IsPathValid every BT tick (~10 Hz)
               while FollowPath is running. If the active {path} starts
               passing through any LETHAL cell (robot ran into something,
               obstacle appeared, costmap updated), IsPathValid returns
               FAILURE, the sequence halts FollowPath immediately, and
               the parent RecoveryNode clears the local costmap and
               retries — by then the 2 Hz replanner has likely written
               a fresh {path}. Without this, FollowPath would keep
               trying to track the dead path until DWB's progress
               checker fired its 8-second movement_time_allowance. -->
          <ReactiveSequence name="MonitorAndFollow">
            <IsPathValid path="{path}"/>
            <FollowPath path="{path}" controller_id="FollowPath"/>
          </ReactiveSequence>
          <ClearEntireCostmap name="ClearLocalCostmap-Context"
            service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="RecoveryActions">
          <BackUp backup_dist="0.30" backup_speed="0.05"/>
          <DriveOnHeading server_name="gradient_escape"
            dist_to_travel="0.0" speed="0.1" time_allowance="15.0"/>
          <Sequence name="ClearingActions">
            <ClearEntireCostmap name="ClearLocalCostmap-Subtree"
              service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Subtree"
              service_name="global_costmap/clear_entirely_global_costmap"/>
          </Sequence>
          <Wait wait_duration="5"/>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
