<!--
  Pass-through BT (branch fix/lines_again_no_bt).

  All BT failure triggers stripped. GoalUpdater → ComputePathToPose
  → FollowPath. No PathFootprintSafe, no RecoveryNode, no recoveries.

  GoalUpdater is kept so 1 Hz GPS goal refreshes don't cancel the
  in-flight FollowPath. Planner runs at 3 Hz; if it ever returns
  FAILURE the goal aborts, but planner is tuned to always emit a
  path (large goal tolerance, allow_unknown).

  Controller is tuned so MPPI never reports FAILURE
  (failure_tolerance: -1, progress checker effectively disabled).
  This means the robot will sit idle if MPPI emits zero velocity
  rather than ever surfacing a failure — by design on this branch.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="NavigateWithReplanning">
      <RateController hz="3.0">
        <GoalUpdater input_goal="{goal}" output_goal="{live_goal}">
          <ComputePathToPose goal="{live_goal}" path="{path}" planner_id="GridBased"/>
        </GoalUpdater>
      </RateController>
      <FollowPath path="{path}" controller_id="FollowPath"/>
    </PipelineSequence>
  </BehaviorTree>
</root>
