<!--
  AutoNav behavior tree — persistent goal pursuit with GoalBender and
  breadcrumb-reverse stuck-extraction.

  Flow:
    1. GoalBender bends the goal toward the front when:
         - the real goal AND the planned path are both behind the robot,
         - OR the path is behind, goal is in front, but the breadcrumb
           buffer is empty (breadcrumb-reverse has nothing left to spend
           so we must turn the robot around).
       Otherwise pass the goal through.
    2. Compute path to the (possibly bent) goal (replan at 3 Hz).
    3. Forward/reverse dispatch:
         - If the path leads forward → FollowPath.
         - Else if path leads behind and goal is in front → spend one
           breadcrumb via the BreadcrumbReverse behavior. Replan next
           tick; if that path is forward, FollowPath resumes.
    4. If everything stalls, cycle through recoveries forever.

  Plan-recovery cascade (mirrors the sim's three-behavior conditional
  flow in bt_sim_gui.py — FORWARD_BLOCKED_BREADCRUMB_REVERSE /
  GRADIENT_ESCAPE / GOAL_BEND):
    1. BreadcrumbReverse — retrace verified-safe forward path. FAILED
       immediately if buffer empty.
    2. GradientEscape    — drive down the inflation gradient until the
       body cell cost drops below the planner's blocking threshold.
       Self-exits as a no-op if the robot is already clear.
    3. ClearCostmap + Wait — return SUCCESS so the outer pipeline retries.
       GoalBender at the top of BendAndPlan re-fires on the next 3 Hz
       tick and bends the goal forward when the buffer is empty AND the
       path leads behind, giving the planner a forward target.
  Blind BackUp is intentionally NOT in this cascade. It was the source
  of unintended rear motion when breadcrumb_reverse fell through (the
  log said "buffer empty" while BackUp commanded a 0.20 m reverse).
  The outer RecoveryFallback round-robin still includes BackUp as the
  last-resort response to a fully-stuck robot.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="999" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <!-- Replan at 3 Hz. The standard Nav2 approach to "what if the
             path becomes invalid?" is just to replan often enough that
             a fresh path naturally replaces a stale one within one
             cycle. 3 Hz matches the global costmap update cadence and
             gives a ~333 ms worst-case staleness window at the planner,
             without the false-positive issues of an explicit
             IsPathValid check (which can fail-cascade into recovery on
             a transient one-tick costmap blip). If Smac refuses to plan
             because the current footprint is already touching high cost,
             PlanRecovery below backs the robot out before retrying. -->
        <RateController hz="3.0">
          <!--
            GoalUpdater intercepts in-mission goal corrections from
            gps_handler_node. It subscribes to /goal_update; each tick
            it copies input_goal -> output_goal, but if a fresh
            /goal_update message has arrived since the last tick the
            output_goal is rewritten in place WITHOUT canceling the
            FollowPath action below.

            This is what keeps the controller running between
            gps_handler's 1 Hz goal refreshes. Previously every fresh
            /goal_pose re-issued NavigateToPose, which canceled the
            in-flight FollowPath, briefly halting the robot until the
            new global path was ready (the stop/go observed during
            mission runs). With GoalUpdater, in-mission corrections
            flow through {live_goal}, the planner re-runs at 3 Hz on
            the new goal, and FollowPath keeps emitting cmd_vel
            uninterrupted as it consumes the next {path} the planner
            writes.
          -->
          <GoalUpdater input_goal="{goal}" output_goal="{live_goal}">
            <Sequence name="BendAndPlan">
              <!-- Bend goal if it's behind the robot -->
              <!-- previous_path feeds prior tick's {path} so the bend fires when the path U-turns. -->
              <GoalBender input_goal="{live_goal}" output_goal="{nav_goal}"
                previous_path="{path}"
                bend_distance="0.8" angle_threshold="2.20" bend_angle="1.05"
                min_lookahead_m="0.6"/>
              <!-- 8 retries × 0.5 s wait = ~4 s of patient retrying
                   before the BT escalates to the heavy RecoveryFallback
                   (BackUp, etc.). The previous 3 × 0.1 s (=0.3 s)
                   budget was tight enough that fresh bring-up timing
                   (SLAM publishing map→odom for the first time, costmap
                   subscribers latching first scan, /tf_static warm-up)
                   would blow through retries and the robot would BackUp
                   instead of just *waiting* for the system to settle —
                   then operators saw "first goal does nothing, second
                   goal works" because the second goal-send arrives
                   after the recovery dance has cleared the start gate.
                   4 s is generous for warm-up while staying short
                   enough that genuinely-unreachable goals still
                   escalate within a reasonable window. ClearCostmap
                   between retries also handles the transient-inflation
                   case the previous PHASEA tuning targeted; this just
                   widens the budget for both. -->
              <RecoveryNode number_of_retries="8" name="ComputePathRecovery">
                <!-- Point-based NavfnPlanner; clearance is enforced by the
                     0.70 m inflation_radius (> 0.682 m circumscribed robot
                     radius). NavfnPlanner has no footprint check, so it
                     refuses to plan only when the body center is on a
                     literal lethal/inscribed cell. The recovery chain
                     below pushes the body off any such cell, then the
                     next tick replans. -->
                <ComputePathToPose goal="{nav_goal}" path="{path}" planner_id="GridBased"/>
                <ReactiveFallback name="PlanRecoveryEscape">
                  <!-- Mirrors the sim's three-behavior conditional cascade
                       (bt_sim_gui.py FORWARD_BLOCKED_BREADCRUMB_REVERSE /
                       GRADIENT_ESCAPE / GOAL_BEND). Blind BackUp was
                       removed: when breadcrumb_reverse can't help (buffer
                       empty), the sim falls through to GOAL_BEND, never
                       to an uninformed reverse. Goal-bending happens at
                       the top of BendAndPlan on every 3 Hz tick — and
                       GoalBender already knows to bend when the path is
                       behind and the breadcrumb buffer is empty — so
                       letting this fallback return SUCCESS (via
                       ClearCostmap+Wait) hands control back to the outer
                       pipeline where GoalBender re-fires and the planner
                       gets a forward plan against the bent goal. -->
                  <!-- 1. If breadcrumbs exist, retrace them. Returns
                          FAILED immediately when the buffer is empty so
                          the fallback advances on the same tick. -->
                  <DriveOnHeading server_name="breadcrumb_reverse"
                    dist_to_travel="0.0" speed="0.1" time_allowance="5.0"/>
                  <!-- 2. If the body is sitting in the inscribed band,
                          drive down the inflation gradient until the
                          planner can seed. gradient_escape now self-exits
                          when robot cell cost drops below 253, so it is a
                          no-op when the robot is already clear. -->
                  <DriveOnHeading server_name="gradient_escape"
                    dist_to_travel="0.0" speed="0.1" time_allowance="15.0"/>
                  <!-- 3. Transient-state escape hatch: clear the local
                          costmap around the robot and pause one tick so
                          GoalBender can re-evaluate against fresh costs.
                          Returning SUCCESS escalates the outer
                          RecoveryNode to retry ComputePathToPose, which
                          runs *after* GoalBender re-fires at the top of
                          BendAndPlan. -->
                  <Sequence name="PlanRecoveryClearThenWait">
                    <ClearCostmapAroundRobot name="ClearAroundRobot-PlanRecovery"
                      service_name="local_costmap/clear_around_local_costmap"
                      reset_distance="1.0"/>
                    <Wait wait_duration="0.5"/>
                  </Sequence>
                </ReactiveFallback>
              </RecoveryNode>
            </Sequence>
          </GoalUpdater>
        </RateController>
        <!-- Controller-first dispatch. The custom forward/reverse gate was
             false-positiveing on valid forward plans, so clear paths showed
             in RViz while FollowPath never ran. Planner output is already
             forward-only (Smac reverse expansion disabled), so MPPI gets the
             first chance to execute every valid plan. -->
        <RecoveryNode number_of_retries="8" name="FollowPathRecovery">
          <!-- Keep planner updates fast, but do not replace the
               FollowPath action for every same-corridor 3 Hz replan.
               PathSignificantlyChanged compares route geometry across
               the full path and also forces a bounded periodic refresh,
               so real tape/cone route changes still reach MPPI while
               identical path refreshes do not churn the action server. -->
          <PathSignificantlyChanged path="{path}" filtered_path="{controller_path}">
            <FollowPath path="{controller_path}" controller_id="FollowPath"/>
          </PathSignificantlyChanged>
          <Sequence name="FollowPathRetryPauseThenClear">
            <Wait wait_duration="0.2"/>
            <ClearCostmapAroundRobot name="ClearAroundRobot-Context"
              service_name="local_costmap/clear_around_local_costmap"
              reset_distance="1.0"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="RecoveryActions">
          <DriveOnHeading server_name="breadcrumb_reverse"
            dist_to_travel="0.0" speed="0.1" time_allowance="5.0"/>
          <BackUp backup_dist="0.20" backup_speed="0.05" time_allowance="6.0"/>
          <BackUp server_name="inflation_backout"
            backup_dist="0.20" backup_speed="0.05" time_allowance="6.0"/>
          <DriveOnHeading server_name="gradient_escape"
            dist_to_travel="0.0" speed="0.1" time_allowance="15.0"/>
          <!-- LOCAL-only clear in the recovery dance. Global wipe was
               removed per sim spec: the global costmap accumulates
               distant obstacles via local_mirror_layer; wiping it makes
               the planner think the world is empty and route through
               invisible walls. -->
          <ClearCostmapAroundRobot name="ClearAroundRobot-Dance"
            service_name="local_costmap/clear_around_local_costmap"
            reset_distance="2.0"/>
          <Wait wait_duration="1"/>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
