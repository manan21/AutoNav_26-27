<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="2" name="FollowPathWithBackupRecovery">
      <FollowPath path="{path}" controller_id="FollowPath"/>
      <BackUp backup_dist="0.15" backup_speed="0.05" time_allowance="5.0"/>
    </RecoveryNode>
  </BehaviorTree>
</root>
