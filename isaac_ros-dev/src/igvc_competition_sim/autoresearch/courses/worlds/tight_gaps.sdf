    <model name='shogi'>
      <pose>0.0000 0.0000 0.1295 0 0 0.000000</pose>
      <link name='base_link'>
        <inertial>
          <mass>90.0</mass>
          <inertia>
            <ixx>4.0</ixx><iyy>8.0</iyy><izz>9.0</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
