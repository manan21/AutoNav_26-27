          <body name="Caster_Wheel" pos="0 -0.045 -0.003">
            <inertial pos="0 0 0" mass="0.35" diaginertia="0.0007 0.0007 0.0004"/>
            <joint name="Caster_Wheel_Roll" pos="0 0 0" axis="1 0 0" limited="false"
