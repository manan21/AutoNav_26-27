              rgba="0.05 0.05 0.05 0" friction="1.05 0.03 0.003"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="right_wheel_velocity" joint="Right_Wheel" kv="8"
              ctrllimited="true" ctrlrange="-30 30"
              forcelimited="true" forcerange="-55 55"/>
    <velocity name="left_wheel_velocity" joint="Left_Wheel" kv="8"
              ctrllimited="true" ctrlrange="-30 30"
              forcelimited="true" forcerange="-55 55"/>
  </actuator>
</mujoco>
