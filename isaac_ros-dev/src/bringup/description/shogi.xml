        </body>
      </body>
      <body name="Right_Wheel_Link" pos="0.37276 -1.7127 0.34419" quat="-7.14974e-07 -3.60295e-06 -0.980874 -0.194646">
        <inertial pos="-0.0370066 -2.47008e-05 1.86946e-05" quat="0.638314 0.769776 8.29338e-07 -6.87704e-07" mass="2.05714" diaginertia="0.0144751 0.00793699 0.00793588"/>
        <joint name="Right_Wheel" pos="0 0 0" axis="1 0 0" limited="false" damping="0.02" armature="0.01"/>
        <geom type="mesh" rgba="1 1 1 1" mesh="Right_Wheel_Link"
              contype="0" conaffinity="0"/>
        <geom name="right_wheel_collision" type="cylinder" pos="-0.04455 0 0"
              quat="0.707107 0 0.707107 0" size="0.113 0.0445"
