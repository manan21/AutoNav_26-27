<?xml version="1.0" encoding="utf-8"?>
<!--
  Shogi robot description — single, sim-complete source of truth.

  Kinematics + visuals feed robot_state_publisher/TF on the real robot exactly
  as before. The added <inertial>, <collision>, and <gazebo> blocks (drive
  plugin, ZED rgbd sensor, wheel/caster friction) plus the articulated caster
  make this URDF spawnable into Gazebo Fortress by autonav_sim's simulator —
  they are INERT outside Gazebo (robot_state_publisher/RViz/Nav2 ignore them).
  The real robot already runs joint_state_publisher, which feeds the non-fixed
  caster joints a neutral 0. Inertial/collision/friction/sensor/plugin values
  are ported verbatim from autonav_sim's generated world (the prior baked SDF).
-->
<robot name="Shogi">
  <link name="base_link">
    <inertial>
      <origin xyz="0.146589 0.000013 0.151663" rpy="0 0 0" />
      <mass value="48.2703" />
      <inertia ixx="2.20" iyy="4.30" izz="4.80" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <collision name="body_collision">
      <origin xyz="0.225 0 0.18" rpy="0 0 0" />
      <geometry>
        <box size="1.09 0.82 0.26" />
      </geometry>
    </collision>
    <visual>
      <origin xyz="-1.712700 -0.778935 -0.344190" rpy="0 0 1.570796" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/base_link.STL" />
      </geometry>
      <material name="base_material">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
  </link>

  <link name="base_footprint" />
  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 -0.113030" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="base_footprint" />
  </joint>

  <link name="Caster_link">
    <inertial>
      <mass value="0.45" />
      <inertia ixx="0.0009" iyy="0.0009" izz="0.0005" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/Caster_link.STL" />
      </geometry>
      <material name="caster_material">
        <color rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
  </link>
  <joint name="Caster" type="continuous">
    <origin xyz="0.577000 -0.000795 -0.040880" rpy="0 -0.000004 0.000007" />
    <parent link="base_link" />
    <child link="Caster_link" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.004" friction="0.0005" />
  </joint>

  <link name="caster_wheel_link">
    <inertial>
      <mass value="0.35" />
      <inertia ixx="0.0007" iyy="0.0007" izz="0.0004" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <collision name="caster_wheel_collision">
      <origin xyz="0 0 0" rpy="1.570796 0 0" />
      <geometry>
        <cylinder radius="0.075" length="0.064" />
      </geometry>
    </collision>
  </link>
  <joint name="Caster_Wheel_Roll" type="continuous">
    <origin xyz="-0.045000 0 -0.013580" rpy="0 0 0" />
    <parent link="Caster_link" />
    <child link="caster_wheel_link" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.003" friction="0.0001" />
  </joint>

  <link name="lidar_footprint">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/Lidar_Link.STL" />
      </geometry>
      <material name="lidar_material">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
  </link>
  <joint name="Lidar" type="fixed">
    <origin xyz="0.659800 0.000105 0.205680" rpy="-3.141593 -0.000004 0" />
    <parent link="base_link" />
    <child link="lidar_footprint" />
  </joint>

  <link name="zed_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/Camera_Link.STL" />
      </geometry>
      <material name="camera_material">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
  </link>
  <joint name="Camera" type="fixed">
    <origin xyz="0.657600 0.009075 0.307230" rpy="0 0.349070 0" />
    <parent link="base_link" />
    <child link="zed_camera_link" />
  </joint>

  <link name="gps_footprint">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/GPS_Link.STL" />
      </geometry>
      <material name="gps_material">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
  </link>
  <joint name="GPS" type="fixed">
    <origin xyz="-0.212200 -0.000105 0.661610" rpy="0 0.000004 0" />
    <parent link="base_link" />
    <child link="gps_footprint" />
  </joint>

  <link name="right_wheel_link">
    <inertial>
      <mass value="2.0" />
      <inertia ixx="0.025" iyy="0.025" izz="0.025" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <collision name="right_drive_wheel_collision">
      <origin xyz="0 0 0" rpy="0 1.570796 0" />
      <geometry>
        <cylinder radius="0.12946" length="0.1" />
      </geometry>
    </collision>
    <visual>
      <origin xyz="0.044545 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/Right_Wheel_Link.STL" />
      </geometry>
      <material name="right_wheel_material">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
  </link>
  <joint name="Right_Wheel" type="continuous">
    <origin xyz="0 -0.361630 0" rpy="2.749800 0 -1.570804" />
    <parent link="base_link" />
    <child link="right_wheel_link" />
    <axis xyz="1 0 0" />
  </joint>

  <link name="left_wheel_link">
    <inertial>
      <mass value="2.0" />
      <inertia ixx="0.025" iyy="0.025" izz="0.025" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <collision name="left_drive_wheel_collision">
      <origin xyz="0 0 0" rpy="0 1.570796 0" />
      <geometry>
        <cylinder radius="0.12946" length="0.1" />
      </geometry>
    </collision>
    <visual>
      <origin xyz="-0.767804 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://bringup/description/meshes/Left_Wheel_Link.STL" />
      </geometry>
      <material name="left_wheel_material">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
  </link>
  <joint name="Left_Wheel" type="continuous">
    <origin xyz="0 0.361630 0" rpy="1.739800 0 1.570796" />
    <parent link="base_link" />
    <child link="left_wheel_link" />
    <axis xyz="1 0 0" />
  </joint>

  <link name="nav_center" />
  <joint name="nav_center_joint" type="fixed">
    <origin xyz="0.225 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="nav_center" />
  </joint>

  <!-- ===== Gazebo (Ignition Fortress) sim extensions — INERT on the real robot ===== -->
  <gazebo reference="base_link">
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
    <sensor name="zed2i_rgbd" type="rgbd_camera">
      <pose>0.657600 0.009075 0.307230 0 0.349070 0</pose>
      <always_on>1</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>
      <topic>/igvc_sim/zed</topic>
      <camera>
        <horizontal_fov>1.453833</horizontal_fov>
        <image>
          <width>960</width>
          <height>540</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.10</near>
          <far>15.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="left_wheel_link">
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
  </gazebo>
  <gazebo reference="caster_wheel_link">
    <mu1>0.75</mu1>
    <mu2>0.02</mu2>
  </gazebo>

  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>Left_Wheel</left_joint>
      <right_joint>Right_Wheel</right_joint>
      <wheel_separation>0.72326</wheel_separation>
      <wheel_radius>0.12946</wheel_radius>
      <topic>/cmd_vel_gazebo</topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
    </plugin>
  </gazebo>
</robot>
